<?xml version="1.0" encoding="UTF-8"?>
<!--
  Verbose, leveled logging for the engine. Console for interactive CLI use,
  rolling file under the data dir for the durable attempt trace. The data dir
  defaults to ./data and is overridable via the MU_DATA_DIR system property.
-->
<configuration>
    <property name="DATA_DIR" value="${MU_DATA_DIR:-./data}" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <!-- Keep the interactive console clean; full DEBUG trace still goes to the log file. -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${DATA_DIR}/logs/manga-utils.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${DATA_DIR}/logs/manga-utils.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Our engine: verbose by default while in development. -->
    <logger name="mangautils" level="DEBUG" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
