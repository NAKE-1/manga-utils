# Keep the build context small + STABLE so editing deploy/ or docs doesn't bust the Gradle build
# cache. Send source, gradlew, and gradle config — nothing else. (BuildKit reads this automatically
# for deploy/Dockerfile; on old Docker, copy it to a root .dockerignore.)
.git
.github
.gradle
**/.gradle
build
**/build
server/webui/node_modules
server/webui/dist
**/node_modules
*.log
.idea
.vscode
# Not needed by the image build (entrypoint is inlined in the Dockerfile):
deploy
docs
*.md
